# LinkedIn Profile Optimizer Agent - Environment Variables
# Copy this file to .env and fill in your values

# JotForm
JOTFORM_API_KEY=your_jotform_api_key_here
JOTFORM_FORM_ID=your_form_id_here
JOTFORM_WEBHOOK_SECRET=your_webhook_secret_here

# Email (voor rapport verzending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM_NAME=Recruitin LinkedIn Optimizer
EMAIL_FROM_ADDRESS=wouter@recruitin.nl

# Pipedrive (optioneel, voor lead management)
PIPEDRIVE_API_KEY=your_pipedrive_api_key_here
PIPEDRIVE_PIPELINE_ID=
